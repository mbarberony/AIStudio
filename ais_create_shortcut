#!/usr/bin/env zsh
# ais_create_shortcut — Create AIStudio desktop shortcut on macOS
# Version: 1.5.4
# Changelog:
#   1.4.3 — codesign --sign - (ad-hoc, removes lock icon); splash after 3s not 0s; Option 2 icon
#   1.4.2 — Info.plist notification keys; splash dialog
#   1.4.1 — add --remove flag
#   1.4.0 — Proper .app bundle (CFBundleName=AIStudio); Launch Agent; splash notification;
#            icon cache store cleared on install; no osacompile dependency
#   1.3.0 — Launch Agent approach; iconutil; killall Dock for icon refresh
#   1.2.0 — iconutil multi-resolution icns
#   1.1.0 — AIStudio.png for icon; default Desktop symlink; --nodesktop flag

# ── Source guard ──────────────────────────────────────────────────────────────
[[ "$ZSH_EVAL_CONTEXT" == *:file* ]] && { echo "❌ Do not source this script — execute it directly."; return 1; }

VERSION="1.5.4"
SCRIPT_NAME="ais_create_shortcut"
SCRIPT_DIR="${0:A:h}"
REPO="$SCRIPT_DIR"
HELP_FILE="$REPO/ais_command_help.txt"

_show_help() {
    if [[ -f "$HELP_FILE" ]]; then
        awk "/^## $SCRIPT_NAME$/,/^---$/" "$HELP_FILE" | grep -v "^---$"
    else
        echo "$SCRIPT_NAME v$VERSION"
        echo ""
        echo "Usage: $SCRIPT_NAME [--help] [--version] [--nodesktop]"
        echo ""
        echo "Create an AIStudio app shortcut on macOS."
        echo "Builds AIStudio.app and installs a Launch Agent."
        echo "Double-clicking the icon starts AIStudio — no Terminal needed."
        echo ""
        echo "Options:"
        echo "  --nodesktop   Skip Desktop symlink (app in ~/Applications only)"
        echo "  --remove      Remove AIStudio shortcut, app, and Launch Agent"
        echo ""
        echo "· macOS only — run once after ais_install"
    fi
}

if [[ "$1" == "--help" ]]; then _show_help; exit 0; fi
if [[ "$1" == "--version" ]]; then echo "$SCRIPT_NAME v$VERSION"; exit 0; fi

# ── --remove: undo everything ais_create_shortcut did ────────────────────────
if [[ "$1" == "--remove" ]]; then
    printf '\033[1m[%s v%s — Remove AIStudio desktop shortcut]\033[0m\n' "$SCRIPT_NAME" "$VERSION"
    echo ""
    echo "--- Removing"
    PLIST_R="$HOME/Library/LaunchAgents/com.aistudio.launcher.plist"
    APP_R="$HOME/Applications/AIStudio.app"
    DESKTOP_R="$HOME/Desktop/AIStudio.app"
    launchctl unload "$PLIST_R" 2>/dev/null && echo "✅ Launch Agent unloaded." || echo "· Launch Agent was not loaded."
    rm -f "$PLIST_R" && echo "✅ Plist removed." || echo "· Plist not found."
    rm -rf "$APP_R" && echo "✅ AIStudio.app removed." || echo "· App not found."
    rm -f "$DESKTOP_R" && echo "✅ Desktop shortcut removed." || echo "· Desktop shortcut not found."
    echo ""
    echo "✅ AIStudio shortcut fully removed."
    echo "· Run ais_create_shortcut again to reinstall."
    exit 0
fi

NODESKTOP=false
[[ "$1" == "--nodesktop" ]] && NODESKTOP=true

printf '\033[1m[%s v%s — Create AIStudio desktop shortcut]\033[0m\n' "$SCRIPT_NAME" "$VERSION"

PNG="$REPO/AIStudio.png"
APP_DIR="$HOME/Applications"
APP_PATH="$APP_DIR/AIStudio.app"
DESKTOP_LINK="$HOME/Desktop/AIStudio.app"
LAUNCH_AGENTS="$HOME/Library/LaunchAgents"
PLIST="$LAUNCH_AGENTS/com.aistudio.launcher.plist"
LABEL="com.aistudio.launcher"
LAUNCH_LOG="$HOME/Library/Logs/AIStudio/launcher.log"
FRONTEND="file://$REPO/front_end/rag_studio.html"

# ── Preflight ─────────────────────────────────────────────────────────────────
echo ""
echo "--- Preflight"

if [[ "$OSTYPE" != "darwin"* ]]; then
    echo "❌ macOS only."
    exit 1
fi

echo "✅ Preflight passed."

# ── Launch Agent ───────────────────────────────────────────────────────────────
echo ""
echo "--- Launch Agent"
echo "▶ Installing com.aistudio.launcher..."

mkdir -p "$LAUNCH_AGENTS"
mkdir -p "$(dirname "$LAUNCH_LOG")"

launchctl unload "$PLIST" 2>/dev/null || true

cat > "$PLIST" << PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.aistudio.launcher</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>$REPO/_ais_create_shortcut_ops.sh</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
        <key>HOME</key>
        <string>$HOME</string>
    </dict>
    <key>RunAtLoad</key>
    <false/>
    <key>StandardOutPath</key>
    <string>$LAUNCH_LOG</string>
    <key>StandardErrorPath</key>
    <string>$LAUNCH_LOG</string>
</dict>
</plist>
PLIST_EOF

launchctl load "$PLIST"
if [[ $? -eq 0 ]]; then
    echo "✅ Launch Agent installed and loaded."
    echo "· Plist: $PLIST"
    echo "· Log:   $LAUNCH_LOG"
else
    echo "❌ Failed to load Launch Agent."
    exit 1
fi

# ── Build .app bundle ─────────────────────────────────────────────────────────
echo ""
echo "--- Building"
echo "▶ Building AIStudio.app bundle..."

# Remove old app first (ensures clean state — no stale osacompile artifacts)
rm -rf "$APP_PATH"
mkdir -p "$APP_PATH/Contents/MacOS"
mkdir -p "$APP_PATH/Contents/Resources"

# Info.plist — CFBundleName controls Login Items display name
cat > "$APP_PATH/Contents/Info.plist" << 'INFO_EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleName</key>
    <string>AIStudio</string>
    <key>CFBundleDisplayName</key>
    <string>AIStudio</string>
    <key>CFBundleIdentifier</key>
    <string>com.aistudio.app</string>
    <key>CFBundleVersion</key>
    <string>1.0</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleExecutable</key>
    <string>AIStudio</string>
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>
    <key>LSMinimumSystemVersion</key>
    <string>12.0</string>
    <key>NSUserNotificationAlertStyle</key>
    <string>alert</string>
    <key>NSUserNotificationsUsageDescription</key>
    <string>AIStudio uses notifications to let you know when services are ready.</string>
</dict>
</plist>
INFO_EOF

# MacOS/AIStudio — the executable
# Shows splash notification, kickstarts Launch Agent, polls health, opens browser
cat > "$APP_PATH/Contents/MacOS/AIStudio" << EXEC_EOF
#!/bin/bash
export PATH="/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:\$PATH"
FRONTEND="$FRONTEND"

# Show splash immediately — user sees feedback right away
osascript -e 'display dialog "AIStudio is starting...\n\nBrowser will open shortly." with title "AIStudio" buttons {"OK"} default button "OK" giving up after 15' &>/dev/null &
SPLASH_PID=\$!

# Kickstart the Launch Agent (starts services in background)
launchctl kickstart -k gui/\$(id -u)/com.aistudio.launcher 2>/dev/null

# Poll /health up to 30 seconds
for i in \$(seq 1 30); do
    sleep 1
    if curl -sf http://localhost:8000/health > /dev/null 2>&1; then
        break
    fi
done

# Dismiss splash and open the frontend (start.sh skips open via --no-open)
kill \$SPLASH_PID 2>/dev/null || true
open "\$FRONTEND"
EXEC_EOF

chmod +x "$APP_PATH/Contents/MacOS/AIStudio"

# Ad-hoc code sign — removes macOS lock icon overlay on unsigned apps
if command -v codesign &>/dev/null; then
    codesign --sign - --force --deep "$APP_PATH" &>/dev/null
    touch "$APP_PATH"
    /System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister -f "$APP_PATH" &>/dev/null
    echo "✅ App signed (ad-hoc) and registered."
fi

echo "✅ AIStudio.app built at $APP_PATH"

# ── Apply icon (iconutil — proper multi-resolution macOS icon) ────────────────
echo ""
echo "--- Icon"
if [[ -f "$PNG" ]] && command -v sips &>/dev/null && command -v iconutil &>/dev/null; then
    echo "▶ Applying AIStudio icon..."
    ICONSET=$(mktemp -d /tmp/AIStudio_XXXXXX.iconset)
    sips -z 16 16     "$PNG" --out "$ICONSET/icon_16x16.png"      &>/dev/null
    sips -z 32 32     "$PNG" --out "$ICONSET/icon_16x16@2x.png"   &>/dev/null
    sips -z 32 32     "$PNG" --out "$ICONSET/icon_32x32.png"       &>/dev/null
    sips -z 64 64     "$PNG" --out "$ICONSET/icon_32x32@2x.png"   &>/dev/null
    sips -z 128 128   "$PNG" --out "$ICONSET/icon_128x128.png"     &>/dev/null
    sips -z 256 256   "$PNG" --out "$ICONSET/icon_128x128@2x.png" &>/dev/null
    sips -z 256 256   "$PNG" --out "$ICONSET/icon_256x256.png"     &>/dev/null
    sips -z 512 512   "$PNG" --out "$ICONSET/icon_256x256@2x.png" &>/dev/null
    sips -z 512 512   "$PNG" --out "$ICONSET/icon_512x512.png"     &>/dev/null
    iconutil -c icns "$ICONSET" -o "$APP_PATH/Contents/Resources/AppIcon.icns" 2>/dev/null
    if [[ $? -eq 0 ]]; then
        echo "✅ Icon applied."
    else
        echo "⚠ iconutil failed — app created without custom icon."
    fi
    rm -rf "$ICONSET"
elif [[ ! -f "$PNG" ]]; then
    echo "⚠ AIStudio.png not found — app created without custom icon."
else
    echo "⚠ Icon tools not available."
fi

# ── Desktop symlink ───────────────────────────────────────────────────────────
echo ""
echo "--- Desktop"
if [[ "$NODESKTOP" == false ]]; then
    ln -sf "$APP_PATH" "$DESKTOP_LINK"
    echo "✅ Shortcut added to Desktop."
else
    echo "ℹ --nodesktop: skipping Desktop shortcut."
fi

# ── Refresh icon cache (full Launch Services database rebuild) ────────────────
echo ""
echo "--- Refresh"
echo "▶ Refreshing icon cache..."
rm -rf ~/Library/Caches/com.apple.iconservices.store 2>/dev/null || true
/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister \
    -r -domain local -domain system -domain user &>/dev/null || true
killall Dock 2>/dev/null || true
echo "✅ Icon cache refreshed."

# ── Reporting ─────────────────────────────────────────────────────────────────
echo ""
echo "--- Done"
echo "✅ AIStudio shortcut ready."
echo "· App location : $APP_PATH"
[[ "$NODESKTOP" == false ]] && echo "· Desktop link : $DESKTOP_LINK"
echo "· Launch Agent : $LABEL"
echo "· To add to Dock: open Finder → ~/Applications → drag AIStudio to Dock"
echo "· Double-click the icon to start AIStudio — no Terminal needed"
echo "· Launch log: $LAUNCH_LOG"
