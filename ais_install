#!/usr/bin/env zsh
# ais_install — AIStudio Command Installer
# Reads ais_user_commands_manifest.yaml to find user command paths and writes aliases to ~/.zshrc
#
# Usage:
#   ./ais_install                    # full install — venv, deps, all user commands
#   ais_install ais_log              # install or update a single user command
#   ais_install --list               # show all installable user commands
#   ais_install --verify             # check which commands are active in .zshrc
#
# Version: 2.4.5
# Changelog: 2.4.6 — Fix manifest parser regex \s+ → \s* to match zero-indented YAML list items (AIStudio_688). First-time install of new commands failed with "not found" because the parser required leading whitespace before "- alias:" but ais_user_commands_manifest.yaml uses no indentation.
# Changelog: 2.4.5 — pip cache purge before install to suppress deserialization warnings (AIStudio_540)
# Changelog: 2.4.4 — stdlib-only manifest parser, no pyyaml required (AIStudio_514)
# Changelog: 2.4.3 — Fix BASH_SOURCE[0] → ${0:A:h} (zsh-native path resolution); fix SCRIPT_DIR undefined before HELP_FILE; remove duplicate REPO/SCRIPT_NAME definitions (AIStudio_499)


# ── Source guard: this script must be executed, not sourced ──────────────────
[[ "$ZSH_EVAL_CONTEXT" == *:file* ]] && { echo "❌ Do not source this script — execute it directly."; return 1; }

VERSION="2.4.6"

SCRIPT_NAME="ais_install"
SCRIPT_DIR="${0:A:h}"
REPO="$SCRIPT_DIR"
HELP_FILE="$REPO/ais_command_help.txt"

_show_help() {
    if [[ -f "$HELP_FILE" ]]; then
        awk "/^## $SCRIPT_NAME$/,/^---$/" "$HELP_FILE" | grep -v "^---$"
    else
        echo "$SCRIPT_NAME v$VERSION"
        echo ""
        echo "Usage: $SCRIPT_NAME [--help] [--version]"
        echo ""
        echo "Run from: ~/Developer/AIStudio"
    fi
}

if [[ "$1" == "--help" ]]; then _show_help; exit 0; fi
if [[ "$1" == "--version" ]]; then echo "$SCRIPT_NAME v$VERSION"; exit 0; fi

SCRIPT_NAME="ais_install"
USER_MANIFEST="$REPO/ais_user_commands_manifest.yaml"
ZSHRC="$HOME/.zshrc"

# ANSI helpers
_bold() { printf '\033[1m%s\033[0m' "$1"; }
_dim()  { printf '\033[2m\033[3m%s\033[0m' "$1"; }
_sep()  { echo "$(_dim "--- $1")"; }

printf '\033[1m[ais_install v%s — AIStudio Command Installer]\033[0m\n' "$VERSION"

# ── Parse user manifest — returns alias|script_path|description ───────────────
_parse_manifest() {
    # stdlib-only YAML parser — no pyyaml required (AIStudio_514)
    # Works before venv activation, on any Python 3.6+
    python3 - "$USER_MANIFEST" "$REPO" << 'PYEOF'
import sys, re
manifest_path, repo = sys.argv[1], sys.argv[2]
commands, current = [], {}
with open(manifest_path) as f:
    for line in f:
        line = line.rstrip()
        if re.match(r"\s*- alias:", line):
            if current:
                commands.append(current)
            current = {"alias": re.sub(r".*alias:\s*", "", line).strip()}
        elif re.match(r"\s*path:", line) and current:
            current["path"] = re.sub(r".*path:\s*", "", line).strip()
        elif re.match(r"\s*description:", line) and current:
            desc = re.sub(r".*description:\s*", "", line).strip().strip("\"'")
            current["description"] = desc
if current:
    commands.append(current)
for e in commands:
    alias, path = e.get("alias"), e.get("path")
    if alias and path:
        print(f"{alias}|{repo}/{path}|{e.get('description', '')}")
PYEOF
}

# ── Write or update a single alias in ~/.zshrc ────────────────────────────────
_write_alias() {
    local alias_name="$1"
    local script_path="$2"
    if grep -q "^alias ${alias_name}=" "$ZSHRC" 2>/dev/null; then
        local existing
        existing=$(grep "^alias ${alias_name}=" "$ZSHRC" | sed "s|^alias ${alias_name}=\"||;s|\".*||")
        local existing_repo
        existing_repo=$(dirname "$(dirname "$existing")" 2>/dev/null)
        if [[ -n "$existing_repo" && "$existing_repo" != "$REPO" && "$existing_repo" != "$(dirname "$REPO")" ]]; then
            echo "  ⚠ $alias_name already points to a different install:"
            echo "    Current: $existing_repo"
            echo "    New:     $REPO"
            echo "    Updating to new path — run \`source ~/.zshrc\` after install."
        fi
        sed -i '' "s|^alias ${alias_name}=.*|alias ${alias_name}=\"${script_path}\"|" "$ZSHRC"
        echo "✅ Updated:   $alias_name"
    else
        echo "alias ${alias_name}=\"${script_path}\"" >> "$ZSHRC"
        echo "✅ Installed: $alias_name"
    fi
}

# ── --list ────────────────────────────────────────────────────────────────────
if [[ "$1" == "--list" ]]; then
    _sep "User Commands"
    _parse_manifest | while IFS='|' read -r alias_name script_path desc; do
        printf "· %-28s %s\n" "$alias_name" "$desc"
    done
    exit 0
fi

# ── --verify ──────────────────────────────────────────────────────────────────
if [[ "$1" == "--verify" ]]; then
    _sep "Verify"
    _parse_manifest | while IFS='|' read -r alias_name script_path desc; do
        if grep -q "^alias ${alias_name}=" "$ZSHRC" 2>/dev/null; then
            echo "✅ $alias_name"
        else
            echo "❌ $alias_name — not found in ~/.zshrc."
        fi
    done
    exit 0
fi

# ── Single command install ─────────────────────────────────────────────────────
if [[ -n "$1" ]]; then
    TARGET="$1"
    _parse_manifest | while IFS='|' read -r alias_name script_path desc; do
        if [[ "$alias_name" != "$TARGET" ]]; then continue; fi
        if [[ ! -f "$script_path" ]]; then
            echo "❌ Script not found: $script_path."
            echo "· Verify the repo is complete: git status"
            exit 1
        fi
        _sep "Alias"
        _write_alias "$alias_name" "$script_path"
        _sep "Next"
        echo "· Run: source ~/.zshrc"
        echo "· Then verify: $alias_name --version"
        exit 0
    done
    echo "❌ Command '$TARGET' not found."
    echo "· Run: ais_install --list"
    exit 1
fi

# ── Full install (no args) ─────────────────────────────────────────────────────
# AIStudio_101: run environment preflight check before installing
CHECK_ENV="$REPO/check_env.sh"
if [[ -f "$CHECK_ENV" ]]; then
    bash "$CHECK_ENV"
    CHECK_EXIT=$?
    if [[ $CHECK_EXIT -ne 0 ]]; then
        echo ""
        echo "❌ Environment check failed — fix the issues above before running ais_install."
        exit 1
    fi
    echo ""
fi

_sep "Environment"
if [[ ! -d "$REPO/.venv" ]]; then
    echo "▶ Creating Python virtual environment..."
    python3 -m venv "$REPO/.venv"
    echo "✅ Virtual environment created."
else
    echo "✅ Virtual environment ready."
fi
echo "▶ Installing Python dependencies..."
source "$REPO/.venv/bin/activate"
pip cache purge --quiet 2>/dev/null || true  # clear stale cache entries (AIStudio_540)
pip install -r "$REPO/requirements.txt" --quiet
echo "✅ Dependencies installed."

_sep "Install"
echo "▶ Installing user commands..."
_parse_manifest | while IFS='|' read -r alias_name script_path desc; do
    _write_alias "$alias_name" "$script_path"
done

source "$ZSHRC"

_sep "Summary"
echo "✅ AIStudio installed."
echo "· Run: source ~/.zshrc"
echo "· Run: ais_install --verify"
echo "· Run: ais_start  to launch AIStudio"
