#!/usr/bin/env zsh
# ais_install_ops — AIStudio Operator Installer
# Extends a user install with all operator ais_* commands.
# Gitignored — travels via BUNDLE only.
#
# Usage (from repo root, after ais_install):
#   ./ais_install_ops
#
# Version: 1.0.0

VERSION="1.0.0"
REPO="$(cd "$(dirname "$0")" && pwd)"

if [[ "$1" == "--version" ]]; then echo "ais_install_ops v$VERSION"; exit 0; fi
if [[ "$1" == "--help" ]]; then
    echo "ais_install_ops v$VERSION"
    echo ""
    echo "Usage: ./ais_install_ops"
    echo ""
    echo "Run once from the repo root after ais_install."
    echo "Installs all operator ais_* commands (deploy, commit, packet, bundle, etc.)."
    echo "This file is gitignored — only available via BUNDLE."
    exit 0
fi

echo ""
echo "+============================================================+"
echo "|        AIStudio — Operator Install  v$VERSION              |"
echo "+============================================================+"
echo ""

# ── Ensure user install is done first ────────────────────────────
MARKER="# ── AIStudio User Commands ──"
if ! grep -q "$MARKER" "$HOME/.zshrc" 2>/dev/null; then
    echo "▶ User install not found — running ais_install first..."
    "$REPO/ais_install"
fi

# ── Install operator aliases ──────────────────────────────────────
echo "▶ Installing operator ais_* commands..."
"$REPO/install_ops"

echo ""
echo "✅ Operator commands installed. Run ais_help_ops for reference."
